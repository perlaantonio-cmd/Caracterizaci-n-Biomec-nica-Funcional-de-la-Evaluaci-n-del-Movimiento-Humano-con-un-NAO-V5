def clasificar_fluidez(angulos):
    if len(angulos) < 6:
        return "Sin datos suficientes", 0.0

    diffs = np.diff(angulos)
    variabilidad = float(np.std(diffs))

    if variabilidad < 2.5:
        return "Movimiento suave", variabilidad
    if variabilidad < 6.0:
        return "Movimiento moderadamente fluido", variabilidad
    return "Movimiento irregular o a tirones", variabilidad


def calcular_fatiga(roms):
    if len(roms) < 6:
        return "No hay repeticiones suficientes para estimar fatiga.", 0.0

    primeras = np.mean(roms[:3])
    ultimas = np.mean(roms[-3:])

    if primeras <= 0:
        return "No se pudo estimar fatiga por falta de ROM inicial valido.", 0.0

    caida = ((primeras - ultimas) / primeras) * 100

    if caida >= 15:
        return f"Posible fatiga: el ROM decayó {caida:.1f}% en las ultimas 3 repeticiones.", caida

    return f"Sin caida relevante de ROM: variacion final {caida:.1f}%.", caida


def interpretar_patron_trampas(detalle_repeticiones):
    reps_con_trampa = [
        rep["repeticion"]
        for rep in detalle_repeticiones
        if rep["resultado"] != "Correcta"
    ]

    total = len(detalle_repeticiones)

    if not reps_con_trampa:
        return "No se observaron compensaciones relevantes durante la serie."

    if total >= 6:
        primeras = set(range(1, 4))
        ultimas = set(range(max(1, total - 2), total + 1))

        trampas_inicio = len([r for r in reps_con_trampa if r in primeras])
        trampas_final = len([r for r in reps_con_trampa if r in ultimas])

        if trampas_final >= 2 and trampas_inicio == 0:
            return (
                "Las compensaciones aparecen principalmente al final de la serie. "
                "Esto sugiere posible fatiga: el paciente logra la tarea, pero pierde control "
                "con la repeticion acumulada. Considerar mantener la carga, reducir repeticiones "
                "o aumentar descanso."
            )

        if trampas_inicio >= 2:
            return (
                "Las compensaciones aparecen desde el inicio. Esto puede indicar que el ejercicio "
                "es demasiado dificil para el nivel actual o que requiere mas instruccion verbal "
                "y demostracion antes de progresar."
            )

    return (
        "Las compensaciones aparecen de forma distribuida. Se recomienda revisar tecnica, ritmo "
        "de ejecucion y control postural antes de progresar carga o volumen."
    )


def recomendacion_clinica(ejercicio, indice_calidad, rom_promedio, objetivo, trampas_totales, roms, fluidez_texto):
    porcentaje_rom = (rom_promedio / objetivo * 100) if objetivo > 0 else 0
    fatiga_texto, caida_fatiga = calcular_fatiga(roms)

    recomendaciones = []

    if indice_calidad >= 80 and porcentaje_rom >= 90 and trampas_totales <= 2:
        if ejercicio.lower().startswith("abduccion") or ejercicio.lower().startswith("rotacion"):
            recomendaciones.append(
                "Progresion de carga: considerar banda elastica ligera de resistencia minima "
                "para fortalecer el manguito rotador sin comprometer la articulacion."
            )
        else:
            recomendaciones.append(
                "Progresion de carga: considerar mancuerna ligera de 0.5 kg a 1 kg, "
                "vigilando que no aparezca brazo doblado, balanceo o compensacion de tronco."
            )

        recomendaciones.append(
            "Dosis de ejercicio: si se mantiene buena tecnica y baja fatiga, el terapeuta "
            "puede valorar aumentar de 10 a 15 repeticiones."
        )

    elif indice_calidad >= 65 and porcentaje_rom >= 75:
        recomendaciones.append(
            "Mantener nivel actual. Priorizar tecnica limpia, control postural y descenso lento "
            "antes de aumentar carga o repeticiones."
        )

    else:
        recomendaciones.append(
            "No progresar carga. Repetir nivel actual con asistencia, descansos suficientes "
            "y vigilancia de compensaciones."
        )

    if caida_fatiga >= 15:
        recomendaciones.append(
            "Monitorear fatiga: la caida de ROM sugiere reducir volumen, aumentar descanso "
            "o disminuir carga."
        )

    if fluidez_texto == "Movimiento irregular o a tirones":
        recomendaciones.append(
            "Control neuromuscular: se observaron cambios bruscos de velocidad. "
            "Recomendar movimiento mas lento y control excentrico durante la bajada."
        )
    else:
        recomendaciones.append(
            "Control motor: la fluidez observada es compatible con una ejecucion controlada "
            "para el nivel evaluado."
        )

    if ejercicio.lower().startswith("abduccion") and indice_calidad >= 80:
        recomendaciones.append(
            "Desafio biomecanico futuro: valorar isometrico a 90 grados durante 5 a 10 segundos "
            "para medir estabilidad de la postura."
        )

    if ejercicio.lower().startswith("rotacion") and rom_promedio >= 55 and indice_calidad >= 80:
        recomendaciones.append(
            "Desafio biomecanico futuro: valorar rotacion externa con ligera abduccion, "
            "solo si el terapeuta confirma estabilidad escapulohumeral."
        )

    recomendaciones.append(fatiga_texto)

    return recomendaciones


def sugerencia_juez(indice_calidad, rom_promedio, objetivo, trampas_totales, fluidez_texto):
    porcentaje_rom = (rom_promedio / objetivo * 100) if objetivo > 0 else 0

    if (
        indice_calidad >= 85
        and porcentaje_rom >= 90
        and trampas_totales <= 2
        and fluidez_texto in ["Movimiento suave", "Movimiento moderadamente fluido"]
    ):
        return "Paciente listo para avanzar a Nivel 2, bajo criterio del terapeuta."

    if indice_calidad >= 65 and porcentaje_rom >= 75:
        return "Mantener en Nivel 1 y reforzar control postural."

    return "Repetir Nivel 1 con asistencia y vigilancia de compensaciones."


