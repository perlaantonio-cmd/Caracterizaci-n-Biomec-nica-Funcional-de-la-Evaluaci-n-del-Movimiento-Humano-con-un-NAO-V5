@app.route("/")
def index():
    return render_template("index.html")


@app.route("/iniciar_terapia", methods=["POST"])
def iniciar_terapia():
    global terapia_activa

    if terapia_activa:
        return jsonify({
            "status": "error",
            "mensaje": "Ya hay una terapia activa"
        }), 409

    data = request.json or {}

    nombre = data.get("nombre", "Paciente")
    brazo = data.get("brazo", "Derecho")
    tipo_rutina = data.get("tipo_rutina", "completa")
    nivel = data.get("nivel", "1")

    if tipo_rutina == "completa":
        ejercicios = RUTINA_COMPLETA
    else:
        ejercicios = data.get("ejercicios", [])

    if not ejercicios:
        return jsonify({
            "status": "error",
            "mensaje": "No seleccionaste ejercicios"
        }), 400

    threading.Thread(
        target=hilo_terapia,
        args=(ejercicios, nombre, brazo, tipo_rutina, nivel),
        daemon=True
    ).start()

    return jsonify({"status": "ok"})


