    if nombre_ejercicio == "codo":
        umbral_reposo_dinamico = 35.0
    else:
        umbral_reposo_dinamico = max(umbral_reposo, objetivo_grados * 0.35)

    reps_buenas = 0
    intentadas = 0
    fase = "REPOSO"

    trampa_en_esta_rep = False
    ultimo_aviso_trampa = 0
    ultimo_aviso_movimiento = 0
    sube_mas_avisado_en_rep = False
    estado_atorado = {"angulo_ref": None, "tiempo_ref": None}

    contador_trampa = 0
    ultima_trampa_detectada = None
    trampas_avisadas_en_rep = set()

    rom_repeticion = 0
    historial_roms = []
    historial_angulos = []
    trampas_cometidas = 0
    trampas_detalle = crear_trampas_detalle()
    detalle_repeticiones = []
    eventos_trampa_rep = []

    angulo_hombro_inicial = 0
    inicio_subida = None

    actualizar_estado(f"Iniciando vision: {nombre_ejercicio}, brazo {brazo}")

    with mp_pose.Pose(min_detection_confidence=0.5, min_tracking_confidence=0.5) as pose:
        while cap.isOpened() and reps_buenas < reps_objetivo:
            ret, frame = cap.read()

            if not ret:
                actualizar_estado("No se pudo leer imagen de la camara")
                break

            frame = cv2.flip(frame, 1)
            h_img, w_img, _ = frame.shape
            rgb = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
            res = pose.process(rgb)

            angulo_actual = 0

            if res.pose_world_landmarks and res.pose_landmarks:
                p3 = res.pose_world_landmarks.landmark
                p2 = res.pose_landmarks.landmark

                hombro, codo, muneca, cadera, h_izq, h_der, cad_izq, cad_der = seleccionar_puntos(p3, brazo)

                angulo_actual = calcular_angulo_ejercicio(
                    nombre_ejercicio,
                    hombro,
                    codo,
                    muneca,
                    cadera
                )

                historial_angulos.append(angulo_actual)

                h_izq_2d = a_px(p2[12], w_img, h_img)
                h_der_2d = a_px(p2[11], w_img, h_img)
                o_izq_2d = a_px(p2[8], w_img, h_img)
                o_der_2d = a_px(p2[7], w_img, h_img)

                p_esternon = [
                    (h_izq_2d[0] + h_der_2d[0]) / 2,
                    (h_izq_2d[1] + h_der_2d[1]) / 2
                ]

                p_craneo = [
                    (o_izq_2d[0] + o_der_2d[0]) / 2,
                    (o_izq_2d[1] + o_der_2d[1]) / 2
                ]

                dx_cuello = abs(p_craneo[0] - p_esternon[0])
                dy_cuello = abs(p_esternon[1] - p_craneo[1])
                inc_cuello = np.arctan2(dx_cuello, dy_cuello) * 180.0 / np.pi

                inc_torso = np.abs(np.arctan2(
                    h_der[1] - h_izq[1],
                    h_der[0] - h_izq[0]
                ) * 180.0 / np.pi)

                if inc_torso > 90:
                    inc_torso = 180 - inc_torso

                actualizar_estado(
                    f"{nombre_ejercicio} {brazo} | angulo {angulo_actual:.1f} | fase {fase} | reps {reps_buenas}/{reps_objetivo}"
                )

                if fase in ["SUBIENDO", "BAJANDO"] and angulo_actual > rom_repeticion:
                    rom_repeticion = angulo_actual

                tipo_trampa = None
                magnitud_trampa = 0.0
                umbral_trampa = 0.0
                ahora = time.time()

                angulo_codo_interno = calcular_angulo_3d(hombro, codo, muneca)
                angulo_hombro = calcular_angulo_3d(cadera, hombro, codo)

                if fase == "SUBIENDO":
                    if nombre_ejercicio in ["abduccion", "flexion"] and inc_torso > 10.0:
                        tipo_trampa = "TRAMPA_TORSO"
                        magnitud_trampa = inc_torso
                        umbral_trampa = 10.0

                    elif nombre_ejercicio in ["abduccion", "flexion"] and inc_cuello > 12.0:
                        tipo_trampa = "TRAMPA_CUELLO"
                        magnitud_trampa = inc_cuello
                        umbral_trampa = 12.0

                    elif nombre_ejercicio in ["abduccion", "flexion"] and angulo_actual > 45 and angulo_codo_interno < 125:
                        tipo_trampa = "TRAMPA_BRAZO_DOBLADO"
                        magnitud_trampa = angulo_codo_interno
                        umbral_trampa = 125.0

                    elif nombre_ejercicio == "rotacion" and angulo_hombro > 40:
                        tipo_trampa = "TRAMPA_CODO_SEPARADO"
                        magnitud_trampa = angulo_hombro
                        umbral_trampa = 40.0

                    elif nombre_ejercicio == "codo":
                        balanceo = abs(angulo_hombro - angulo_hombro_inicial)
                        if balanceo > 25:
                            tipo_trampa = "TRAMPA_BALANCEO"
                            magnitud_trampa = balanceo
                            umbral_trampa = 25.0

                if tipo_trampa:
                    if tipo_trampa == ultima_trampa_detectada:
                        contador_trampa += 1
                    else:
                        contador_trampa = 1
                        ultima_trampa_detectada = tipo_trampa
                else:
                    contador_trampa = 0
                    ultima_trampa_detectada = None

                if tipo_trampa and contador_trampa >= 8:
                    if tipo_trampa not in trampas_avisadas_en_rep:
                        trampas_avisadas_en_rep.add(tipo_trampa)
                        trampas_detalle[tipo_trampa] += 1
                        trampas_cometidas += 1
                        trampa_en_esta_rep = True

                        repeticion_estimada = intentadas + 1

                        eventos_trampa_rep.append(
                            crear_evento_trampa(
                                tipo_trampa,
                                repeticion_estimada,
                                angulo_actual,
                                magnitud_trampa,
                                umbral_trampa
                            )
                        )

                        if ahora - ultimo_aviso_trampa > 4:
                            enviar_comando_nao(tipo_trampa)
                            ultimo_aviso_trampa = ahora

                if fase == "REPOSO" and angulo_actual > umbral_inicio:
                    fase = "SUBIENDO"
                    trampa_en_esta_rep = False
                    sube_mas_avisado_en_rep = False
                    estado_atorado = {"angulo_ref": angulo_actual, "tiempo_ref": ahora}
                    trampas_avisadas_en_rep.clear()
                    eventos_trampa_rep = []
                    rom_repeticion = angulo_actual
                    angulo_hombro_inicial = angulo_hombro
                    inicio_subida = ahora

                    if ahora - ultimo_aviso_movimiento > 3:
                        enviar_comando_nao("ACOMPANAR_" + nombre_ejercicio.upper())
                        ultimo_aviso_movimiento = ahora

                elif fase == "SUBIENDO" and angulo_actual >= objetivo_grados:
                    intentadas += 1
                    numero_rep = intentadas
                    historial_roms.append(rom_repeticion)
                    fase = "BAJANDO"
                    inicio_subida = None

                    if eventos_trampa_rep:
                        nombres = ", ".join([e["nombre"] for e in eventos_trampa_rep])
                        magnitud_max = max([e["magnitud"] for e in eventos_trampa_rep])
                        intervencion = eventos_trampa_rep[0]["intervencion"]
                        resultado_rep = "Incorrecta"
                    else:
                        nombres = "Ninguna"
                        magnitud_max = 0.0
                        intervencion = "Ninguna"
                        resultado_rep = "Correcta"

                    detalle_repeticiones.append({
                        "repeticion": numero_rep,
                        "resultado": resultado_rep,
                        "trampa": nombres,
                        "magnitud": round(float(magnitud_max), 1),
                        "angulo_rom": round(float(rom_repeticion), 1),
                        "intervencion": intervencion,
                        "eventos": list(eventos_trampa_rep)
                    })

                    if not trampa_en_esta_rep:
                        reps_buenas += 1
                        enviar_comando_nao("EXCELENTE")

                    actualizar_estado(f"Repeticion registrada: {reps_buenas}/{reps_objetivo}")

                elif fase == "SUBIENDO":
                    falta_mucho = angulo_actual < (objetivo_grados - 10)
                    atorado = actualizar_atorado(estado_atorado, angulo_actual, ahora)

                    if falta_mucho and atorado and not sube_mas_avisado_en_rep:
                        enviar_comando_nao("SUBE_MAS_" + nombre_ejercicio.upper())
                        sube_mas_avisado_en_rep = True

                elif fase == "BAJANDO" and angulo_actual < umbral_reposo_dinamico:
                    fase = "REPOSO"
                    inicio_subida = None

            else:
                actualizar_estado("No se detecta postura. Ponte frente a la camara.")

            if MOSTRAR_CAMARA:
                if res.pose_landmarks:
                    mp_dibujo.draw_landmarks(frame, res.pose_landmarks, mp_pose.POSE_CONNECTIONS)

                cv2.putText(
                    frame,
                    f"{nombre_ejercicio} {brazo} | Rep: {reps_buenas}/{reps_objetivo} | Ang: {int(angulo_actual)} | {fase}",
                    (10, 40),
                    cv2.FONT_HERSHEY_SIMPLEX,
                    0.7,
                    (0, 255, 0),
                    2
                )

                cv2.imshow("Monitor Terapia", frame)

                if cv2.waitKey(1) & 0xFF == ord("q"):
                    break

    cap.release()

    if MOSTRAR_CAMARA:
        cv2.destroyAllWindows()

    fluidez_texto, fluidez_valor = clasificar_fluidez(historial_angulos)

    actualizar_estado(
        f"Ejercicio terminado: {nombre_ejercicio} {brazo}. Buenas: {reps_buenas}, intentadas: {intentadas}"
    )

    return {
        "reps_buenas": reps_buenas,
        "intentadas": intentadas,
        "trampas_totales": trampas_cometidas,
        "trampas_detalle": trampas_detalle,
        "historial_rom": historial_roms,
        "fluidez": fluidez_texto,
        "fluidez_valor": fluidez_valor,
        "detalle_repeticiones": detalle_repeticiones
    }


# =========================================================================
# HILO PRINCIPAL
# =========================================================================

def hilo_terapia(ejercicios, nombre_paciente, brazo_seleccionado, tipo_rutina, nivel):
    global reporte_listo, terapia_activa

    reporte_listo = None
    terapia_activa = True

    timestamp_str = datetime.now().strftime("%Y%m%d_%H%M%S")
    datos_reporte = []

    try:
        if brazo_seleccionado == "Ambos":
            brazos_a_trabajar = ["Derecho", "Izquierdo"]
        else:
            brazos_a_trabajar = [brazo_seleccionado]

        for clave in ejercicios:
            if clave not in CONFIG_MOVIMIENTOS:
                continue

            config = CONFIG_MOVIMIENTOS[clave]

            for brazo in brazos_a_trabajar:
                if tipo_rutina == "completa":
                    enviar_comando_nao(config["comando"] + "_COMPLETA")
                else:
                    enviar_comando_nao(config["comando"] + "_PERSONALIZADA")

                datos_ejercicio = {
                    "ejercicio": config["nombre"],
                    "objetivo": config["objetivo"],
                    "engagement_time": 0,
                    "reps_buenas": 0,
                    "intentadas": 0,
                    "trampas_totales": 0,
                    "trampas_detalle": crear_trampas_detalle(),
                    "historial_rom": [],
                    "brazo": brazo,
                    "fluidez": "Sin datos suficientes",
                    "fluidez_valor": 0.0,
                    "detalle_repeticiones": []
                }

                series_a_hacer = config["series"]
                tiempo_inicio_espera = time.time()
                fluidez_valores = []

                for serie_actual in range(1, series_a_hacer + 1):
                    if serie_actual == 1:
                        actualizar_estado("Esperando boton Paciente listo para iniciar la primera serie...")
                    else:
                        enviar_comando_nao("MITAD_SERIE")
                        time.sleep(40)
                        enviar_comando_nao("FIN_DESCANSO")
                        actualizar_estado("Esperando boton Paciente listo para iniciar la siguiente serie...")

                    evento_paciente_listo.clear()
                    evento_paciente_listo.wait()

                    if serie_actual == 1:
                        datos_ejercicio["engagement_time"] = time.time() - tiempo_inicio_espera

                    resultado = ejecutar_vision_terapia(
                        clave,
                        config["objetivo"],
                        config["reps"],
                        brazo
                    )

                    datos_ejercicio["reps_buenas"] += resultado["reps_buenas"]
                    datos_ejercicio["intentadas"] += resultado["intentadas"]
                    datos_ejercicio["trampas_totales"] += resultado["trampas_totales"]
                    datos_ejercicio["historial_rom"].extend(resultado["historial_rom"])
                    datos_ejercicio["detalle_repeticiones"].extend(resultado["detalle_repeticiones"])
                    sumar_trampas_detalle(datos_ejercicio["trampas_detalle"], resultado["trampas_detalle"])

                    fluidez_valores.append(resultado["fluidez_valor"])
                    datos_ejercicio["fluidez"] = resultado["fluidez"]
                    datos_ejercicio["fluidez_valor"] = float(np.mean(fluidez_valores)) if fluidez_valores else 0.0

                    buenas_serie = resultado["reps_buenas"]
                    intentadas_serie = resultado["intentadas"]
                    porcentaje_serie = (buenas_serie / intentadas_serie * 100) if intentadas_serie > 0 else 0

                    enviar_comando_nao(
                        f"REPORTE_SERIE:{config['nombre']}:{serie_actual}:{intentadas_serie}:{buenas_serie}:{porcentaje_serie:.1f}"
                    )

                    time.sleep(6)

                datos_reporte.append(datos_ejercicio)

        total_intentadas = sum(ej["intentadas"] for ej in datos_reporte)
        total_buenas = sum(ej["reps_buenas"] for ej in datos_reporte)
        total_trampas = sum(ej["trampas_totales"] for ej in datos_reporte)
        porcentaje_total = (total_buenas / total_intentadas * 100) if total_intentadas > 0 else 0

        enviar_comando_nao(
            f"REPORTE_FINAL:{total_intentadas}:{total_buenas}:{porcentaje_total:.1f}:{total_trampas}"
        )

        enviar_comando_nao("FIN_RUTINA_TOTAL")
        generar_reporte_pdf(datos_reporte, nombre_paciente, timestamp_str, nivel)

    except Exception as e:
        actualizar_estado(f"Error en terapia: {e}")

    finally:
        terapia_activa = False


