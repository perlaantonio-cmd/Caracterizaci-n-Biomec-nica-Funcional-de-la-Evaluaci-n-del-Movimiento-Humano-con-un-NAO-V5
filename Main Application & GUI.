def seleccionar_puntos(p, brazo):
    if brazo == "Izquierdo":
        hombro = a_3d(p[12])
        codo = a_3d(p[14])
        muneca = a_3d(p[16])
        cadera = a_3d(p[24])
    else:
        hombro = a_3d(p[11])
        codo = a_3d(p[13])
        muneca = a_3d(p[15])
        cadera = a_3d(p[23])

    h_izq = a_3d(p[12])
    h_der = a_3d(p[11])
    cad_izq = a_3d(p[24])
    cad_der = a_3d(p[23])

    return hombro, codo, muneca, cadera, h_izq, h_der, cad_izq, cad_der


def calcular_angulo_ejercicio(nombre_ejercicio, hombro, codo, muneca, cadera):
    if nombre_ejercicio in ["abduccion", "flexion"]:
        return calcular_angulo_3d(cadera, hombro, codo)

    if nombre_ejercicio == "codo":
        angulo_interno = calcular_angulo_3d(hombro, codo, muneca)
        return max(0.0, 180.0 - angulo_interno)

    if nombre_ejercicio == "rotacion":
        vec_antebrazo = np.array(muneca) - np.array(codo)
        rotacion = np.degrees(np.arctan2(abs(vec_antebrazo[0]), abs(vec_antebrazo[2])))
        return abs(rotacion)

    return 0.0


